# Auto detect text files and perform LF normalization
* text=auto eol=lf

# C# / .NET source
*.cs        text diff=csharp
*.vb        text
*.fs        text diff=fsharp
*.fsx       text diff=fsharp

# Project / build files
*.csproj    text merge=union
*.vbproj    text merge=union
*.fsproj    text merge=union
*.dbproj    text merge=union
*.sln       text merge=union eol=crlf
*.props     text merge=union
*.targets   text merge=union

# XAML / markup
*.xaml      text
*.axaml     text
*.xml       text
*.config    text
*.json      text
*.yml       text
*.yaml      text
*.md        text

# Shell / scripts
*.sh        text eol=lf
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.bmp       binary
*.webp      binary
*.pdf       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.eot       binary
*.dll       binary
*.exe       binary
*.pdb       binary
*.snk       binary
*.zip       binary
*.7z        binary
